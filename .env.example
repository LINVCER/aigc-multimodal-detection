# ======== 数据库 ========
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=image_nious
MYSQL_USER=root
MYSQL_PASSWORD=change-me-in-production
MYSQL_ROOT_PASSWORD=change-me-in-production

# SQLAlchemy 连接字符串 (由上述变量拼接)
DATABASE_URL=mysql+aiomysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}

# ======== Redis ========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ======== MinIO (文件存储) ========
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=image-nious-files
MINIO_SECURE=false

# ======== JWT ========
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ======== LLM API (OpenAI 兼容接口) ========
# 当前使用 DeepSeek API
LLM_API_KEY=sk-5fde2f682c194c8992f30fe91542fab9
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 其他可选模型:
# OpenAI:     LLM_API_BASE=https://api.openai.com/v1   LLM_MODEL=gpt-4o
# 通义千问:    LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
# 智谱GLM:    LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4  LLM_MODEL=glm-4
# 月之暗面:    LLM_API_BASE=https://api.moonshot.cn/v1  LLM_MODEL=moonshot-v1-8k

# 注意: LLM logprob 检测分支需要 API 支持 logprobs 参数
# DeepSeek 和 OpenAI 支持此功能，其他 API 可能不支持（会自动降级）

# ======== Resemble AI API ========
RESEMBLE_AI_API_KEY=your-resemble-ai-key
RESEMBLE_AI_MONTHLY_LIMIT=1000

# ======== MiMo-VL 视觉语言模型 (Anthropic 兼容 API) ========
MIMO_API_KEY=tp-ckcc4ib4j528eudeqbu6qvqgm8bwbsm9qwp4wd4y9pes1zah
MIMO_API_BASE=https://token-plan-cn.xiaomimimo.com/anthropic
MIMO_MODEL=mimo-v2.5-pro[1m]

# ======== 模型路径 (HuggingFace model ID, 首次使用自动下载) ========
TEXT_MODEL_PATH=hfl/chinese-roberta-wwm-ext
IMAGE_VIT_MODEL_PATH=openai/clip-vit-large-patch14
IMAGE_CNN_MODEL_PATH=../models/image/cnn_detection.pth
AUDIO_RAWNET2_MODEL_PATH=../models/audio/rawnet2_model.pth

# ======== 服务端口 ========
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ======== CORS ========
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,chrome-extension://*

# ======== 日志 ========
LOG_LEVEL=INFO
